{
  "id": "openclaw-workspace",
  "name": "OpenClaw Workspace",
  "version": "0.1.0",
  "description": "Surface OpenClaw memory files and artifacts directly inside Lumina.",
  "entry": "index.js",
  "permissions": [
    "commands:register",
    "events:subscribe",
    "ui:decorate",
    "ui:notify",
    "workspace:integrations",
    "workspace:open",
    "workspace:tab",
    "vault:list",
    "vault:read"
  ],
  "enabled_by_default": true
}
